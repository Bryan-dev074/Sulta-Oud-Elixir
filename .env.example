# Copia este archivo a .env.local y completa los valores.
# Las variables SECRETAS (sin NEXT_PUBLIC_) solo se usan en el servidor.

# --- Publicas (la tienda las usa para leer el catalogo) ---
NEXT_PUBLIC_SUPABASE_URL=https://fpzmdezcmbyplbdngcke.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_bHgBBQYPKg3QgHkL5H24MQ_yjB0pQw4
NEXT_PUBLIC_WHATSAPP_NUMBER=595982064334

# --- Secretas (el panel /admin las necesita para leer/escribir en la base) ---
# Clave SECRETA de Supabase (Settings > API Keys > Secret keys, sb_secret_...).
# SIN ella el panel /admin sale vacio y crear/editar/eliminar productos falla.
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: si no se define, se usa NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=
# Contrasena del panel /admin (si se omite, usa el default de site-config.ts).
ADMIN_PASSWORD=
# Recomendada: cadena larga y aleatoria para firmar la cookie de sesion.
ADMIN_SESSION_SECRET=

# --- Google Sheets (boton "Sincronizar planilla" del panel /admin) ---
# Cuenta de Servicio de Google Cloud con la Google Sheets API habilitada.
# IMPORTANTE: compartir la planilla con este email (rol Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# private_key del JSON de la cuenta de servicio. Pegala COMPLETA y entre comillas:
# incluye los \n literales (-----BEGIN PRIVATE KEY-----\n...\n-----END...).
GOOGLE_PRIVATE_KEY=
# Opcional: ID de la planilla. Si se omite, usa el default del codigo.
GOOGLE_SHEET_ID=1nyRu64ZE7Cg4v93Z8s_5wFulm7-YbsOAVXeh3Kuk1-Q

# --- Asistente de carga de productos (IA + scraping) ---
# Gemini (datos del perfume: marca, ml, notas, descripcion). Consegui la key en
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: modelo de Gemini (default gemini-2.5-flash; "gemini-3.5-flash" NO existe).
GEMINI_MODEL=gemini-2.5-flash
